{
  "firestore": {
    "database": "(default)",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },

  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,

      "ignore": [
        "node_modules"
      ],

      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],

  "emulators": {
    "auth": {
      "port": 9099
    },

    "functions": {
      "port": 5001
    },

    "firestore": {
      "port": 8080
    },

    "ui": {
      "enabled": true,
      "port": "4000"
    }
  }
}
